      {
        "data": {
          "id": "installation",
          "text": "Installation"
        },
        "children": [
          {
            "data": {
              "id": "install-mac-linux",
              "text": "macOS / Linux"
            },
            "children": [
              {
                "data": {
                  "id": "install-mac-cmd",
                  "text": "curl -sSf https://…/install.sh | sh"
                },
                "children": []
              }
            ]
          },
          {
            "data": {
              "id": "install-windows",
              "text": "Windows (PowerShell)"
            },
            "children": [
              {
                "data": {
                  "id": "install-win-cmd",
                  "text": "irm https://…/install.ps1 | iex"
                },
                "children": []
              }
            ]
          },
          {
            "data": {
              "id": "install-source",
              "text": "From Source"
            },
            "children": [
              {
                "data": {
                  "id": "install-cargo",
                  "text": "cargo build --workspace"
                },
                "children": []
              },
              {
                "data": {
                  "id": "install-prereqs",
                  "text": "Requires: Rust, Chrome (auto-provisioned)"
