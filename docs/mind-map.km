{
  "root": {
    "data": {
      "id": "root",
      "text": "UTO — Unified Testing Object"
    },
    "children": [
      {
        "data": {
          "id": "what-is-uto",
          "text": "What is UTO?"
        },
        "children": [
          {
            "data": {
              "id": "uto-tagline",
              "text": "Vision-first, cross-platform test automation engine"
            },
            "children": []
          },
          {
            "data": {
              "id": "uto-language",
              "text": "Written in Rust"
            },
            "children": []
          },
          {
            "data": {
              "id": "uto-replaces",
              "text": "Built to replace Cypress & Playwright"
            },
            "children": []
          },
          {
            "data": {
              "id": "uto-selector-free",
              "text": "Selector-free tests — targets user intent, not CSS/XPath"
            },
            "children": []
          },
          {
            "data": {
              "id": "uto-unified",
              "text": "Unified Web + Mobile in one framework"
            },
            "children": []
          },
          {
            "data": {
              "id": "uto-zero-config",
              "text": "Zero-config — discover first, provision when missing"
            },
            "children": []
          },
          {
            "data": {
              "id": "uto-cross-platform",
              "text": "Cross-platform by design: macOS, Linux, Windows"
            },
            "children": []
          }
        ]
      },
      {
        "data": {
          "id": "why-uto",
          "text": "Why UTO?"
        },
        "children": [
          {
            "data": {
              "id": "why-vs-cypress",
              "text": "vs Cypress"
            },
            "children": [
              {
                "data": {
                  "id": "cypress-web-only",
                  "text": "Cypress is web-only — no mobile support"
                },
                "children": []
              },
              {
                "data": {
                  "id": "cypress-selectors",
                  "text": "Cypress relies on brittle CSS selectors"
                },
                "children": []
              }
            ]
          },
          {
            "data": {
              "id": "why-vs-playwright",
              "text": "vs Playwright"
            },
            "children": [
              {
                "data": {
                  "id": "playwright-no-mobile",
                  "text": "Playwright has no native mobile automation"
                },
                "children": []
              },
              {
                "data": {
                  "id": "playwright-selector-brittle",
                  "text": "Playwright tests break on design system refactors"
                },
                "children": []
              }
            ]
          },
          {
            "data": {
              "id": "uto-advantage",
              "text": "UTO Advantages"
            },
            "children": [
              {
                "data": {
                  "id": "adv-vision",
                  "text": "Vision-driven element recognition"
                },
                "children": []
              },
              {
                "data": {
                  "id": "adv-mobile",
                  "text": "Web + Android + iOS — same API"
                },
                "children": []
              },
              {
                "data": {
                  "id": "adv-reporting",
                  "text": "Reporting-first observability"
                },
                "children": []
              },
              {
                "data": {
                  "id": "adv-performance",
                  "text": "Compiled Rust performance"
                },
                "children": []
              }
            ]
          }
        ]
